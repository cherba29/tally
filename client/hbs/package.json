{
  "name": "@tally/client",
  "private": true,
  "version": "0.3.0",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@graphql-codegen/cli": "^5.0.0",
    "@jest/globals": "^29.7.0",
    "@types/chai": "^4.3.11",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.19.30",
    "css-loader": "^7.1.3",
    "eslint": "^9.39.2",
    "eslint-config-google": "^0.14.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nyc": "^15.1.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@apollo/client": "^3.8.8",
    "@tally/lib": "workspace:*",
    "graphql": "^16.8.1",
    "lit": "^3.3.2",
    "prettier": "^3.8.1"
  },
  "scripts": {
    "serve": "TS_NODE_PROJECT=\"tsconfig-for-webpack-config.json\" webpack serve --port 9000",
    "build": "TS_NODE_PROJECT=\"tsconfig-for-webpack-config.json\" webpack --config webpack.config.ts",
    "karma": "karma start karma.conf.js",
    "graphql-codegen": "graphql-codegen --config codegen.yml",
    "coverage": "nyc -r text -e .ts -x \"tests/*.test.ts\" npm run test",
    "prettier-format": "prettier --config .prettierrc.yaml '**/*.ts' --write",
    "lint": "eslint . --ext .ts",
    "lint-fix": "eslint . --ext .ts --fix"
  }
}
